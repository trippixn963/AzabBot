# ============================================================================
# SaydnayaBot Configuration
# ============================================================================
# This file contains all configuration settings for the bot.
# Copy this file to .env and fill in your values.
# ============================================================================

# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Developer Configuration (only this ID can control the bot)
DEVELOPER_ID=your_discord_user_id_here

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Prison Channel Configuration (optional - bot auto-detects by keywords)
# Add specific channel IDs here if keyword detection isn't enough
PRISON_CHANNEL_IDS=

# Target Role Configuration
# Users with this role will trigger bot responses
TARGET_ROLE_ID=

# Database Configuration
DATABASE_DIR=data

# Log Management
LOG_DIR=logs
LOG_RETENTION_DAYS=7

# Bot Behavior (these are the optimal settings - don't change)
AZAB_MODE_ENABLED=true
AZAB_PROBABILITY=0.7